<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="내 페르소나"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 캐릭터 자리 -->
        <TextView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="12dp"
            android:layout_gravity="center"
            android:background="#DDDDDD"
            android:text="(캐릭터자리)" />

        <TextView
            android:id="@+id/growth_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="Lv.1"
            android:textSize="14sp"
            android:textStyle="bold"    />

        <TextView
            android:id="@+id/growth_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="일기 0편 누적"
            android:textSize="12sp"    />

        <!-- 구분선 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bubble_box"
            android:padding="14dp"
            android:orientation="vertical">

            <!-- 감정 통계 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="감정 지표"
                android:textSize="15sp"
                android:textStyle="bold"    />

            <!-- 감정별 행 -->
            <LinearLayout
                android:id="@+id/stat_row_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/stat_label_1"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:textSize="13sp" />

                <View
                    android:id="@+id/stat_bar_1"
                    android:layout_width="0dp"
                    android:layout_height="14dp"
                    android:layout_weight="0"
                    android:background="#F0997B" />

                <TextView
                    android:id="@+id/stat_count_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/stat_row_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/stat_label_2"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:textSize="13sp" />

                <View
                    android:id="@+id/stat_bar_2"
                    android:layout_width="0dp"
                    android:layout_height="14dp"
                    android:layout_weight="0"
                    android:background="#85B7EB" />

                <TextView
                    android:id="@+id/stat_count_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/stat_row_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/stat_label_3"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:textSize="13sp" />

                <View
                    android:id="@+id/stat_bar_3"
                    android:layout_width="0dp"
                    android:layout_height="14dp"
                    android:layout_weight="0"
                    android:background="#9FE1CB" />

                <TextView
                    android:id="@+id/stat_count_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/stat_row_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/stat_label_4"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:textSize="13sp" />

                <View
                    android:id="@+id/stat_bar_4"
                    android:layout_width="0dp"
                    android:layout_height="14dp"
                    android:layout_weight="0"
                    android:background="#FAC775" />

                <TextView
                    android:id="@+id/stat_count_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/stat_row_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/stat_label_5"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:textSize="13sp" />

                <View
                    android:id="@+id/stat_bar_5"
                    android:layout_width="0dp"
                    android:layout_height="14dp"
                    android:layout_weight="0"
                    android:background="#F09595" />

                <TextView
                    android:id="@+id/stat_count_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
